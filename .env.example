#-------------------------------
# Application Configuration
#-------------------------------
# Application name (used for Docker containers and project identification)
APP_NAME=__PROJECT_SLUG__
# Environment (development/staging/production)
APP_ENV_KEY=development
# Public URL of the application
APP_URL=http://localhost:3030
# Port the server listens on
APP_PORT=3030
# Path to compiled assets
APP_DIST_PATH=static/dist

#-------------------------------
# Database Configuration
#-------------------------------
# Database host for local development
DB_HOST=127.0.0.1
# Database port
DB_PORT=3406
# Database user credentials
DB_USER=youruser
DB_PASSWORD=yourpassword
# Database name
DB_NAME=yourdatabase
# Docker container database host
DB_HOST_DOCKER=__PROJECT_SLUG__-postgres

#-------------------------------
# Session Management
#-------------------------------
# Session storage type (file/redis)
SESSION_STORE=redis
# Key used in context for session data
SESSION_CONTEXT_KEY=session
# Cookie name for session ID
SESSION_NAME=session_id
# Cookie name for admin session ID
SESSION_ADMIN_NAME=admin_session_id
# Session length in minutes
SESSION_LENGTH=60

#-------------------------------
# File-based Session Config
#-------------------------------
# Directory to store session files
SESSION_FILE_PATH=tmp/sessions

#-------------------------------
# Redis Session Config
#-------------------------------
# Redis connection details
SESSION_REDIS_HOST=localhost
SESSION_REDIS_PORT=6379
SESSION_REDIS_PASSWORD=
# Redis database number
SESSION_REDIS_DB=0

#-------------------------------
# Application-Specific Configuration
#-------------------------------
# Application display name
APP_NAME="__PROJECT_DISPLAY_NAME__ Application"
# Application version
APP_VERSION="1.0.0"
# Debug mode
APP_DEBUG=true

# Feature flags
FEATURE_REGISTRATION=true
FEATURE_USER_PROFILES=true
FEATURE_NOTIFICATIONS=false
MAINTENANCE_MODE=false

# Pagination settings
PAGINATION_DEFAULT_LIMIT=20
PAGINATION_MAX_LIMIT=100

# Upload settings
UPLOAD_MAX_FILE_SIZE=10485760  # 10MB in bytes
UPLOAD_PATH="static/uploads"

#-------------------------------
# Admin Session Configuration
#-------------------------------
# Separate session cookie for admin panel (prevents scope leakage)
ADMIN_SESSION_NAME=admin_session_id
# Session length for admin sessions in minutes (shorter for security)
ADMIN_SESSION_LENGTH=30

#-------------------------------
# Stripe Configuration
#-------------------------------
# Stripe secret key (server-side only — never expose to client)
STRIPE_SECRET_KEY=sk_test_...
# Stripe publishable key (safe for frontend JS)
STRIPE_PUBLISHABLE_KEY=pk_test_...
# Stripe webhook signing secret (from Stripe Dashboard → Webhooks)
STRIPE_WEBHOOK_SECRET=whsec_...
# Platform commission percentage (e.g. 15 = 15%)
STRIPE_COMMISSION_PERCENT=15

#-------------------------------
# Email / SMTP Configuration
#-------------------------------
# Email driver: smtp | log (log prints to stdout, safe for development)
MAIL_DRIVER=log
# From address for all platform emails
MAIL_FROM=noreply@humaculture.com
MAIL_FROM_NAME=Humaculture
# SMTP connection details (used when MAIL_DRIVER=smtp)
MAIL_SMTP_HOST=smtp.example.com
MAIL_SMTP_PORT=587
MAIL_SMTP_USER=
MAIL_SMTP_PASSWORD=
MAIL_SMTP_TLS=true

#-------------------------------
# File Storage Configuration
#-------------------------------
# Storage driver: local | s3 | gcs
STORAGE_DRIVER=local

# Local storage (when STORAGE_DRIVER=local)
STORAGE_LOCAL_ROOT=./assets/storage
STORAGE_PUBLIC_ROOT=./static

# S3-compatible storage (when STORAGE_DRIVER=s3)
# Works with: AWS S3, Linode Object Storage, DigitalOcean Spaces, MinIO
S3_ENDPOINT=                    # e.g. https://us-ord-1.linodeobjects.com (blank for AWS)
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_PREFIX=uploads/              # optional path prefix inside bucket

# Google Cloud Storage (when STORAGE_DRIVER=gcs)
GCS_BUCKET=
GCS_CREDENTIALS_FILE=           # path to service account JSON
GCS_PREFIX=uploads/

# CDN (optional — works with any remote driver)
# When set, public file URLs use CDN instead of direct S3/GCS URLs
CDN_URL=                        # e.g. https://cdn.humaculture.com

#-------------------------------
# Rate Limiting
#-------------------------------
# Enable/disable rate limiting globally
RATE_LIMIT_ENABLED=true
# Backing store: "memory" (single instance) or "redis" (multi-instance)
RATE_LIMIT_STORE=memory
# Response format for 429 errors: "json" or "html"
RATE_LIMIT_RESPONSE_FORMAT=json
# Log denied requests to the rate_limit_logs database table
RATE_LIMIT_LOG_TABLE=false
# Trusted reverse proxies (comma-separated IPs or CIDRs)
RATE_LIMIT_TRUSTED_PROXIES=
# Default policy values
RATE_LIMIT_DEFAULT_LIMIT=300
RATE_LIMIT_DEFAULT_WINDOW=60
RATE_LIMIT_DEFAULT_BURST=60

#-------------------------------
# Rate Limiting Redis Config
#-------------------------------
# Falls back to SESSION_REDIS_* values if not set
RATE_LIMIT_REDIS_HOST=localhost
RATE_LIMIT_REDIS_PORT=6379
RATE_LIMIT_REDIS_PASSWORD=
RATE_LIMIT_REDIS_DB=0
# Key prefix for all rate-limit keys in Redis
RATE_LIMIT_REDIS_PREFIX=__PROJECT_SLUG__:rl:

#-------------------------------
# Frontend Development (Vite)
#-------------------------------
# Path to Vite's manifest file
VITE_MANIFEST_PATH=static/dist/.vite/manifest.json
# Vite development server port
VITE_PORT=5173
