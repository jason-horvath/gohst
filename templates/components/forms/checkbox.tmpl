{{ define "forms/checkbox" }}
<div class="space-y-2">
  {{ range .Options }}
  <label class="flex items-center gap-2 cursor-pointer">
    <input
      class="w-4 h-4 rounded border-gray-300 text-sky-600 focus:ring-sky-500 dark:border-gray-600 dark:bg-gray-800"
      {{ attrs $.Attrs }}
      type="checkbox"
      id="{{ .ID }}"
      name="{{ .Name }}"
      value="{{ .Value }}"
      {{ if .Checked }}checked{{ end }}
    />
    <span class="text-sm font-medium">{{ .Label }}</span>
  </label>
  {{ end }}
</div>
{{ end }}
