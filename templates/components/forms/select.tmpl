{{ define "forms/select" }}
<select
  class="block w-full px-5 py-4 leading-6 border border-gray-200 rounded-lg focus:border-sky-500 focus:ring-3 focus:ring-sky-500/50 dark:border-gray-600 dark:bg-gray-800 dark:focus:border-sky-500"
  {{ attrs .Attrs }}
  id="{{ .ID }}"
  name="{{ .Name }}"
>
  {{ range .Options }}
  <option value="{{ .Value }}" {{ if .Selected }}selected{{ end }}>{{ .Label }}</option>
  {{ end }}
</select>
{{ end }}
