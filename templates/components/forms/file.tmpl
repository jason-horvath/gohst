{{ define "forms/file" }}
<input
  class="block w-full px-5 py-4 leading-6 border border-gray-200 rounded-lg cursor-pointer focus:border-sky-500 focus:ring-3 focus:ring-sky-500/50 dark:border-gray-600 dark:bg-gray-800 dark:focus:border-sky-500"
  {{ attrs .Attrs }}
  type="file"
  id="{{ .ID }}"
  name="{{ .Name }}"
  {{ if .Accept }}accept="{{ .Accept }}"{{ end }}
  {{ if .Multiple }}multiple{{ end }}
/>
{{ if .Placeholder }}<p class="mt-1 px-2 text-sm text-gray-500 dark:text-gray-400">{{ .Placeholder }}</p>{{ end }}
{{ end }}
