    echo "
      в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—  в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв•—  в–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—
     в–Ҳв–Ҳв•”в•җв•җв•җв•җв•қ в–Ҳв–Ҳв•”в•җв•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв•җв•җв•қв•ҡв•җв•җв–Ҳв–Ҳв•”в•җв•җв•қ
     в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—   в–Ҳв–Ҳв•‘
     в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•‘в•ҡв•җв•җв•җв•җв–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘
     в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв•ҡв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—   в–Ҳв–Ҳв•‘
      в•ҡв•җв•җв•җв•җв•җв•қ  в•ҡв•җв•җв•җв•җв•җв•қ в•ҡв•җв•қ  в•ҡв•җв•қв•ҡв•җв•җв•җв•җв•җв•җв•қ   в•ҡв•җв•қ

 ---------------------------------------------------

 рҹ‘»рҹ‘»рҹ‘» GOHST DEVELOPMENT SERVER STARTING... рҹ‘»рҹ‘»рҹ‘»

 ---------------------------------------------------

 Using port: $APP_PORT

"
}

# Function to determine the correct watch command based on OS
get_watch_command() {
    # Mac OS
    if [[ "$(uname -s)" == "Darwin" ]]; then
        echo "fswatch -r --event Updated --event Created --event Removed \
            -e '/\.git/' \
            -e '/\.git/index.lock' \
            -e '/vendor/' \
            -e '/cmd/dev/' \
            -e '/tmp/' \
            -e '/node_modules/' \
            -e '/static/dist/' \
            -e '/static/.vite/' \
            -e '/logs/' \
            -e '\.rdb$' \
            -e '_templ\.go$' \
            \"$WATCH_DIR_ABS\""
    # Linux Distros
    elif [[ "$(uname -s)" == "Linux" ]]; then
        echo "inotifywait -m -r -e modify,create,delete \
            --exclude '(\.git|vendor|cmd/dev|tmp|node_modules|static/dist|static/.vite|logs|\.rdb|_templ\.go)' \
            \"$WATCH_DIR_ABS\""
    else
        echo "вқҢвқҢвқҢ Unsupported OS. Exiting. вқҢвқҢвқҢ" >&2
        exit 1
    fi
}

# Watch for changes in the WATCH_DIR
watch_for_changes() {
    # Convert WATCH_DIR to an absolute path
    WATCH_DIR="$ROOT_DIR"

    echo "рҹ”„ Watching for file changes in $WATCH_DIR - Restarting on changes!"
     # Restart the application
    echo "рҹҡҖ Starting Gohst server..."
    cd "$ROOT_DIR" || exit 1
    gohst_log_header > "tmp/gohst.log"
    $APP_BUILD_CMD >> tmp/gohst.log 2>&1
    nohup $APP_RUN_CMD >> tmp/gohst.log 2>&1 & disown
    echo "рҹ‘» Gohst server started! рҹ‘»"
    echo "----------------------------"
    echo "Go to: $APP_URL"
    echo ""

    WATCH_CMD=$(get_watch_command)

    eval $WATCH_CMD | while read FILE_CHANGE; do
        clear

        # Stop Vite
        "$VITE_PROCESS" "stop"

        # Ensure FILE_CHANGE is not empty
        if [ -n "$FILE_CHANGE" ]; then
            echo "рҹ”Қ Change detected: $FILE_CHANGE"
        else
            echo "вқ—пёҸ No file change detected! Check $WATCH_DIR path or exclusions."
            continue
        fi

        echo "рҹ”„ Detected changes. Restarting server..."

        # Kill process running on APP_PORT
        echo "рҹӣ‘ Stopping process on port $APP_PORT..."
        echo -n "вҢӣ Waiting for process to fully exit..."
        # Wait until the port is free
        until ! lsof -ti :$APP_PORT >/dev/null; do
            echo -n "."
            kill -9 $(lsof -ti :$APP_PORT) 2>/dev/null
            sleep 0.2 # Give it some time to fully release
        done

        echo ""
        echo "вң… Process on port $APP_PORT fully stopped!"

        # Restart the application
        echo "рҹҡҖ Restarting Gohst server..."
        cd "$ROOT_DIR" || exit 1
        echo "рҹ‘» Gohst server restarting..." >> "tmp/gohst.log"
        $APP_BUILD_CMD >> tmp/gohst.log 2>&1
        nohup $APP_RUN_CMD >> tmp/gohst.log 2>&1 & disown

        # start Vite
        "$VITE_PROCESS" "start"
        echo "рҹ‘» Gohst server restarted! рҹ‘»"
        echo ""
    done

    # Kill process running on APP_PORT
    if lsof -ti :$APP_PORT >/dev/null; then
        echo "рҹӣ‘ Stopping process on port $APP_PORT..."
        kill -9 $(lsof -ti :$APP_PORT)
    fi

    echo ""
    echo ""
    echo "=== рҹ‘» Gohst watch interrupted рҹ‘» ===
    "
}

# Stop the server
stop_server() {
    echo "рҹӣ‘ Stopping all processes on port $APP_PORT..."
    lsof -ti :$APP_PORT | xargs kill -9 2>/dev/null

    sleep 2

    # Force kill lingering processes
    if lsof -ti :$APP_PORT >/dev/null; then
        lsof -ti :$APP_PORT | xargs kill -9 2>/dev/null
        echo "рҹӣ‘ Force killed remaining processes!"
    fi

    echo "рҹӣ‘ Stopped all processes on port $APP_PORT!"
}

# Handle script arguments
case "$1" in
    start)
        watch_for_changes
        ;;
    stop)
        stop_server
        ;;
    *)
        echo "Usage: $0 {start|stop|restart}"
        exit 1
        ;;
esac
