package viewforms

import ft "gohst/internal/forms"

templ Input(v ft.Text) {
	<input
		class="block w-full px-5 py-4 leading-6 placeholder-gray-500 border border-gray-200 rounded-lg focus:border-sky-500 focus:ring-3 focus:ring-sky-500/50 dark:border-gray-600 dark:bg-gray-800 dark:placeholder-gray-400 dark:focus:border-sky-500"
		{ v.TemplAttrs()... }
		type={ v.Type }
		id={ v.ID }
		name={ v.Name }
		placeholder={ v.Placeholder }
		value={ v.Value }
	/>
}
